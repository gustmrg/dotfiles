{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "kimi_dark_primary": "#4FA8FF",
    "kimi_dark_accent": "#5BC0BE",
    "kimi_dark_text": "#E0E0E0",
    "kimi_dark_strong": "#F5F5F5",
    "kimi_dark_dim": "#888888",
    "kimi_dark_muted": "#6B6B6B",
    "kimi_dark_border": "#5A5A5A",
    "kimi_dark_bg": "#121212",
    "kimi_dark_panel": "#1A1A1A",
    "kimi_dark_error": "#FF5252",
    "kimi_light_primary": "#1565C0",
    "kimi_light_accent": "#00838F",
    "kimi_light_text": "#1A1A1A",
    "kimi_light_strong": "#1A1A1A",
    "kimi_light_dim": "#454545",
    "kimi_light_muted": "#5F5F5F",
