      "light": "kimi_light_accent"
    },
    "markdownBlockQuote": {
      "dark": "kimi_dark_dim",
      "light": "kimi_light_dim"
    },
    "markdownEmph": {
      "dark": "kimi_dark_strong",
      "light": "kimi_light_strong"
    },
    "markdownStrong": {
      "dark": "kimi_dark_strong",
      "light": "kimi_light_strong"
    },
    "markdownHorizontalRule": {
      "dark": "kimi_dark_border",
      "light": "kimi_light_border"
    },
    "markdownListItem": {
      "dark": "kimi_dark_primary",
      "light": "kimi_light_primary"
    },
    "markdownListEnumeration": {
      "dark": "kimi_dark_accent",
      "light": "kimi_light_accent"
    },
    "markdownImage": {
      "dark": "kimi_dark_primary",
      "light": "kimi_light_primary"
    },
    "markdownImageText": {
      "dark": "kimi_dark_accent",
      "light": "kimi_light_accent"
    },
    "markdownCodeBlock": {
      "dark": "kimi_dark_text",
      "light": "kimi_light_text"
    },
    "syntaxComment": {
      "dark": "kimi_dark_muted",
      "light": "kimi_light_muted"
    },
    "syntaxKeyword": {
      "dark": "kimi_dark_primary",
      "light": "kimi_light_primary"
    },
    "syntaxFunction": {
      "dark": "kimi_dark_strong",
      "light": "kimi_light_strong"
    },
    "syntaxVariable": {
      "dark": "kimi_dark_text",
      "light": "kimi_light_text"
    },
    "syntaxString": {
      "dark": "kimi_dark_accent",
      "light": "kimi_light_accent"
    },
    "syntaxNumber": {
      "dark": "kimi_dark_accent",
      "light": "kimi_light_accent"
    },
    "syntaxType": {
      "dark": "kimi_dark_primary",
      "light": "kimi_light_primary"
    },
    "syntaxOperator": {
      "dark": "kimi_dark_primary",
      "light": "kimi_light_primary"
    },
    "syntaxPunctuation": {
      "dark": "kimi_dark_dim",
      "light": "kimi_light_dim"
    }
  }
}

