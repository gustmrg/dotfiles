      "light": "kimi_light_error"
    },
    "warning": {
      "dark": "kimi_dark_accent",
      "light": "kimi_light_accent"
    },
    "success": {
      "dark": "kimi_dark_accent",
      "light": "kimi_light_accent"
    },
    "info": {
      "dark": "kimi_dark_primary",
      "light": "kimi_light_primary"
    },
    "text": {
      "dark": "kimi_dark_text",
      "light": "kimi_light_text"
    },
    "textMuted": {
      "dark": "kimi_dark_muted",
      "light": "kimi_light_muted"
    },
    "background": {
      "dark": "kimi_dark_bg",
      "light": "kimi_light_bg"
    },
    "backgroundPanel": {
      "dark": "kimi_dark_panel",
      "light": "kimi_light_panel"
